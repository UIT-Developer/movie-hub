# Next.js Web Application Configuration
NODE_ENV=development
PORT=4200

# In Docker Compose, `localhost` refers to the container itself.
# Use the compose service name and internal port instead.
NEXT_PUBLIC_API_URL=http://api-gateway:3000/api/v1
NEXT_PUBLIC_BACKEND_API_URL=http://api-gateway:3000/api/v1
NEXT_PUBLIC_WEBSOCKET_URL=ws://api-gateway:3000

# Optional: required only if you want Clerk auth enabled in the web app
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
